[TX] svc=DOWNLINK_DATA   sndr=02 rcvr=01 seq=  2 dst=01 targets=[1] fragment=(1/1, len=42) text='Orbit stable. Borrow camera. Send map now.'
Provider state: BORROW_DONE (15)
Borrower state: BORROW_DONE (15)
